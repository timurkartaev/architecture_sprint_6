        </mxCell>
        <mxCell id="6Lu1mzsPtpnjW-voY9vB-100" value="&lt;b&gt;Проксирование&lt;/b&gt;&lt;div&gt;&lt;b&gt;запросов&lt;/b&gt;&lt;/div&gt;&lt;div&gt;[HTTP(S)]&lt;/div&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" vertex="1" connectable="0" parent="6Lu1mzsPtpnjW-voY9vB-99">
