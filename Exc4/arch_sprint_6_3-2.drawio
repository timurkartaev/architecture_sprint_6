        <mxCell id="6Lu1mzsPtpnjW-voY9vB-98" value="Оформление страховок&lt;div&gt;[REST]&lt;/div&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];" vertex="1" connectable="0" parent="6Lu1mzsPtpnjW-voY9vB-97">
