        <mxCell id="p61_fYt2mJc75AFhNHWi-21" value="Запись команды для отправки заявки ОСАГО/&lt;div&gt;Чтение событий по статусу заявки ОСАГО&lt;div&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;[TCP]&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;fontStyle=1" vertex="1" connectable="0" parent="p61_fYt2mJc75AFhNHWi-20">
